# Supabase public browser credentials only.
# Copy this file to .env.local and fill these values from the Supabase project dashboard.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Admin login uses Supabase Auth plus the database allow-list boundary (`is_admin()` / `admin_users`).
# Provision admin users externally; never from the frontend.

# NEVER store service-role keys, database passwords, personal tokens, or other secrets in
# VITE_* variables, .env.local commits, frontend code, or versioned files.
